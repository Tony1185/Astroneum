}

.term-pattern-header {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid var(--term-border);
  flex-shrink: 0;
}

.term-pattern-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--term-text);
  flex: 1;
}

.term-pattern-body {
  flex: 1;
  overflow-y: auto;
  padding: 8px 0;
}

.term-pattern-group {
  padding: 0 16px 8px;
}

.term-pattern-group-label {
  font-size: 10px;
  font-weight: 600;
  color: var(--term-text-2);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 8px 0 4px;
}

.term-pattern-row {
  display: flex;
  align-items: center;
  gap: 8px;
  height: 28px;
  cursor: pointer;
  user-select: none;
}

.term-pattern-row-label {
  font-size: 12px;
  color: var(--term-text);
}

.term-pattern-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 10px 16px;
  border-top: 1px solid var(--term-border);
  flex-shrink: 0;
}
